PDP_HTTP_ADDR=:8080
PDP_DB_URL=
PDP_LOG_LEVEL=info
PDP_ENABLE_METRICS=true
PDP_ENABLE_OWNERSHIP=true
PDP_STEPUP_MAX_AGE=30m
PDP_STEPUP_ACTIONS=admin:*,*:delete
PDP_STEPUP_AAL=2
PDP_CACHE_TTL=0s
PDP_DECISION_CACHE_TTL=0s
PDP_RATE_LIMIT_PER_MIN=120
PDP_RATE_LIMIT_BURST=30
PDP_MAX_HEADER_BYTES=65536
PDP_CLIENT_ID_HEADER=
PDP_TLS_CERT_FILE=
PDP_TLS_KEY_FILE=
PDP_TLS_CLIENT_CA_FILE=
PDP_REQUIRE_CLIENT_CA=false
PDP_ADMIN_TOKEN=__SET_STRONG_TOKEN__
PDP_INTERNAL_TOKEN=__SET_STRONG_TOKEN__
PDP_METRICS_TOKEN=__SET_STRONG_TOKEN__
PDP_POLICY_FILE=
PDP_REDIS_URL=
PDP_ENV=production
AUDIT_BASE_URL=
AUDIT_INTERNAL_TOKEN=
PDP_AUDIT_SPOOL_DIR=
AUDIT_ALLOW_INSECURE_HTTP=false
